        "graphMode": "area",
        "textMode": "value",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": ""
          },
          "query": "from(bucket: \"telemetry\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"battery_telemetry\")\n  |> filter(fn: (r) => r._field == \"voltage_v\")\n  |> aggregateWindow(every: 30s, fn: mean, createEmpty: false)\n  |> yield(name: \"voltage_v\")",
          "refId": "A"
